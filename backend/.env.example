# MySQL 連線字串(TiDB Serverless 需附 TLS 參數,例:
# mysql://<user>:<pass>@<host>:4000/attendance_db?sslaccept=strict)
DATABASE_URL=

# JWT 驗簽金鑰(請使用長度足夠的隨機字串,例:openssl rand -base64 48)
JWT_SECRET=

# JWT 過期時間(可選,預設由程式決定)
JWT_EXPIRES_IN=1d

# 服務埠(雲端平台如 Render 會自動注入 PORT)
PORT=3001

# seed 時所有使用者的初始密碼(bcrypt 雜湊後寫入)
DEFAULT_USER_PASSWORD=

# 允許的前端來源(CORS 允許清單,逗號分隔)
FRONTEND_URL=http://localhost:5173

# 可選:CI/建置環境略過啟動時 DB 連線
# SKIP_DB_CONNECT=true
# 可選:DB 初始連線失敗直接拋錯
# PRISMA_STRICT_CONNECT=true
